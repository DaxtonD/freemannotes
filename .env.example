# Copy to .env for local runs.

NODE_ENV=production
PORT=27015
# Bind host for server.js (use 0.0.0.0 in containers)
HOST=0.0.0.0
# Optional public base URL used for startup logs (does not change routing)
# APP_URL=https://dev.freeman.daxtond.com

# Optional: enable Yjs server persistence (LevelDB).
# YPERSISTENCE=/data/yjs

# Optional override. Usually leave unset and let the app use same-origin /yjs.
# VITE_WS_URL=wss://dev.freeman.daxtond.com/yjs

# ─── PostgreSQL (Prisma) ─────────────────────────────────────────────
# Required for server-side Yjs document persistence.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://freemannotes:freemannotes@localhost:5432/freemannotes?schema=public

# Optional: control schema sync behavior at startup.
# - deploy: applies committed migrations (recommended)
# - push:   prisma db push (dev convenience)
# - none:   skip automatic schema sync
 DB_SCHEMA_SYNC=deploy

# ─── PostgreSQL Timezone ──────────────────────────────────────────────
# IANA timezone name used for displaying timestamps from PostgreSQL.
# Internal storage remains UTC; this setting only affects how timestamps
# are presented in API responses and query results.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# PGTIMEZONE=America/Regina
# PGTIMEZONE=America/Chicago
# PGTIMEZONE=Europe/London

# ─── Redis (optional) ────────────────────────────────────────────────
# When set, the server caches Yjs doc state in Redis for faster loads
# and can use pub/sub for multi-instance coordination.
# Format: redis://[:PASSWORD@]HOST:PORT
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:yourpassword@localhost:6379

# ─── Auth (Phase 11) ────────────────────────────────────────────────
# Required for JWT cookie sessions (register/login).
# Use a long random value in production.
AUTH_JWT_SECRET=change-me-in-production
# Optional overrides
# AUTH_COOKIE_NAME=freemannotes_session
# AUTH_SESSION_DAYS=14
# AUTH_BCRYPT_ROUNDS=12
# AUTH_ALLOW_REGISTER=true

# ─── SMTP (Invites) ──────────────────────────────────────────────────
# Required for workspace invite emails (SMTP-only as configured).
SMTP_HOST=smtp.purelymail.com
SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=freeman@daxtond.com
SMTP_PASS=TD1PO4WlZXETiDNN
SMTP_FROM="FreemanNotes <no-reply@example.com>"

# ─── Uploads ─────────────────────────────────────────────────────────
# Directory where profile images are stored.
# In Docker, map a volume to this path.
UPLOAD_DIR=/app/uploads

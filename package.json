{
  "name": "freemannotes",
  "version": "1.0.9",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "node server/waitForServer.js && vite --host",
    "predev:server": "npm run db:generate || echo prisma generate failed",
    "dev:server": "node server/dbInitCli.js && node server.js",
    "prestart": "npm run db:generate || echo prisma generate failed",
    "start": "npm run build && node server.js",
    "prestart:server": "npm run db:generate || echo prisma generate failed",
    "start:server": "node server.js",
    "db:init": "node server/dbInitCli.js",
    "preview": "vite preview --host",
    "ws": "node ws-server.js",
    "build": "vite build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push",
    "postinstall": "prisma generate || echo prisma generate failed",
    "release:patch": "npm version patch -m \"chore(release): v%s\" && git push && git push --tags",
    "release:minor": "npm version minor -m \"chore(release): v%s\" && git push && git push --tags",
    "release:major": "npm version major -m \"chore(release): v%s\" && git push && git push --tags",
    "test": "node --test tests/"
  },

# Vite build-time env vars (only VITE_* are exposed to the client)
# Copy to env.vite/.env.production or env.vite/.env.development if needed.

# Optional: override Vite dev/preview ports.
# Useful if you want to run dev behind a reverse proxy on a specific port.
# VITE_DEV_PORT=5173
# VITE_PREVIEW_PORT=4173

# Optional override. Usually leave unset and let the app use same-origin /yjs.
# VITE_WS_URL=wss://dev.freeman.daxtond.com/yjs

# Optional: where Vite should proxy /api/* and /uploads/* in dev.
# If you run `npm run dev`, the backend defaults to http://localhost:27015.
# VITE_API_PROXY_TARGET=http://localhost:27015

# Optional: embed an in-memory Yjs websocket backend inside Vite on /yjs.
# Default is OFF; instead, Vite proxies /yjs to the backend so dev sees your
# persisted notes.
# VITE_YJS_EMBED=1

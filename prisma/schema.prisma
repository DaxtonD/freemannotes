// ─────────────────────────────────────────────────────────────────────────
// Prisma schema for FreemanNotes – Phase 10 (Production Persistence Layer)
//
// PostgreSQL is the canonical source of truth for all document state.
// Yjs in-memory docs are ephemeral runtime state only.
// Redis remains a pub/sub + cache layer only.
// IndexedDB remains client-side cache only.
//
// Design constraints:
//   - System is anonymous (no auth yet) — ready for Phase 11 auth.
//   - No language columns — locale is a client concern.
//   - No markdown-specific schema — metadata lives inside the Yjs map.
//   - Horizontally scalable: multiple app instances share Postgres + Redis.
//
// Migrations:
//   Dev:        npx prisma migrate dev --name <label>
//   Production: npx prisma migrate deploy
//   Client:     npx prisma generate
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  // Output into node_modules/.prisma/client (default location).
  // Docker builds run `prisma generate` after `npm ci`.
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is read from the environment (.env or docker-compose).
  // Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
  url = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Workspace – lightweight tenant boundary.
//
// Every note collection belongs to exactly one workspace. The default setup
// creates a single "default" workspace automatically (seeded on first boot).
// Future multi-tenant support (Phase 11) can create additional workspaces
// associated with different users or organizations.
// ─────────────────────────────────────────────────────────────────────────
model Workspace {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable workspace name (e.g. "My Notes", "Team Alpha").
  name String @default("default")

  /// Optional: owner/creator user ID for future auth integration (Phase 11).
  /// Not enforced at DB level — purely informational until auth is added.
  ownerUserId String? @map("owner_user_id")

  /// Timestamps for auditing.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// One workspace owns many documents.
  documents Document[]

  // Enforce unique workspace names to prevent accidental duplicates.
  @@unique([name])
  @@map("workspace")
}

// ─────────────────────────────────────────────────────────────────────────
// Document – persisted Yjs document state (binary snapshot).
//
// Each Yjs room (identified by `docId`) maps to one row. The `state`
// column stores the full Yjs document as `Y.encodeStateAsUpdate` output
// (Uint8Array → Postgres BYTEA). The server writes this column on a
// debounced schedule and on client disconnect, ensuring durable storage
// that survives server restarts.
//
// `stateVector` stores `Y.encodeStateVector` output for efficient
// incremental sync when clients reconnect.
//
// All note metadata (title, type, trashedAt, etc.) is stored INSIDE the
// Yjs document's metadata Y.Map — not as separate SQL columns. This
// keeps the schema stable as features are added.
// ─────────────────────────────────────────────────────────────────────────
model Document {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Foreign key to the owning workspace.
  workspaceId String @map("workspace_id") @db.Uuid

  /// Yjs room name — matches the room name used by y-websocket.
  /// For individual notes this is the noteId (e.g. "abc123").
  /// For the notes registry this is "__notes_registry__".
  /// Globally unique — one room name maps to exactly one persisted doc.
  docId String @unique @map("doc_id")

  /// Full Yjs document state as Y.encodeStateAsUpdate(doc) output.
  /// This is a binary blob (Uint8Array serialized to Postgres BYTEA).
  state Bytes

  /// Yjs state vector for efficient delta sync.
  /// Stored as Y.encodeStateVector(doc) output.
  stateVector Bytes @map("state_vector")

  /// Timestamp of the initial creation.
  createdAt DateTime @default(now()) @map("created_at")

  /// Timestamp of the last successful persistence write.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relation to the parent workspace.
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Index for fast workspace-scoped queries (list all docs in a workspace).
  @@index([workspaceId])
  @@map("document")
}

// ─────────────────────────────────────────────────────────────────────────
// UserPreference – per-user configurable settings.
//
// Stores user-level preferences that influence server-side behaviour
// (e.g. how long trashed notes are retained before permanent deletion).
// The table is keyed by `userId` — a free-form string that will map to
// a future auth identity (Phase 11). Until then, the server uses a
// deterministic default user ID (e.g. "default").
// ─────────────────────────────────────────────────────────────────────────
model UserPreference {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// User identifier. Until auth is implemented, the server uses a
  /// fixed default value (e.g. "default"). Must be unique per user.
  userId String @unique @map("user_id")

  /// Number of days a trashed note is retained before automatic
  /// permanent deletion. Must be a positive integer.
  /// Default: 30 days.
  deleteAfterDays Int @default(30) @map("delete_after_days")

  /// Timestamps for auditing.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_preference")
}

// ─────────────────────────────────────────────────────────────────────────
// Prisma schema for FreemanNotes server-side Yjs document persistence.
//
// This schema stores workspace-scoped Yjs document snapshots in PostgreSQL.
// Each row in `yjs_document` holds the binary state vector for one Yjs room
// (either a note doc or the __notes_registry__ meta-doc). The `workspace`
// table provides a lightweight identity boundary so a single server instance
// can host multiple independent note collections.
//
// Migrations are generated with:  npx prisma migrate dev --name <label>
// Production push (no migration):  npx prisma db push
// Client regeneration:             npx prisma generate
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  // Output into node_modules/.prisma/client (default location).
  // Docker builds run `prisma generate` after `npm ci`.
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is read from the environment (.env or docker-compose).
  // Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
  url = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Workspace – lightweight tenant boundary.
//
// Every note collection belongs to exactly one workspace. The default setup
// creates a single "default" workspace automatically (seeded on first boot).
// Future multi-tenant support can create additional workspaces associated
// with different users or organizations.
// ─────────────────────────────────────────────────────────────────────────
model Workspace {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable workspace name (e.g. "My Notes", "Team Alpha").
  name String @default("default")

  /// Optional: owner/creator user ID for future auth integration.
  /// Not enforced at DB level — purely informational until auth is added.
  ownerUserId String? @map("owner_user_id")

  /// Timestamps for auditing.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// One workspace owns many Yjs document snapshots.
  documents YjsDocument[]

  // Enforce unique workspace names to prevent accidental duplicates.
  @@unique([name])
  @@map("workspace")
}

// ─────────────────────────────────────────────────────────────────────────
// YjsDocument – persisted Yjs document state (binary snapshot).
//
// Each Yjs room (identified by `docId`) maps to one row per workspace.
// The `state` column stores the full Yjs document as `Y.encodeStateAsUpdate`
// output (Uint8Array → Postgres BYTEA). The server writes this column on
// a debounced schedule and on client disconnect, ensuring durable storage
// that survives server restarts.
//
// The optional `stateVector` column stores `Y.encodeStateVector` output
// for efficient incremental sync when clients reconnect.
// ─────────────────────────────────────────────────────────────────────────
model YjsDocument {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Foreign key to the owning workspace.
  workspaceId String @map("workspace_id") @db.Uuid

  /// Yjs room name — matches the room name used by y-websocket.
  /// For individual notes this is the noteId (e.g. "abc123").
  /// For the notes registry this is "__notes_registry__".
  docId String @map("doc_id")

  /// Full Yjs document state as Y.encodeStateAsUpdate(doc) output.
  /// This is a binary blob (Uint8Array serialized to Postgres BYTEA).
  state Bytes

  /// Optional Yjs state vector for efficient delta sync.
  /// Stored as Y.encodeStateVector(doc) output.
  stateVector Bytes? @map("state_vector")

  /// Timestamp of the last successful persistence write.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Timestamp of the initial creation.
  createdAt DateTime @default(now()) @map("created_at")

  /// Relation to the parent workspace.
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Compound unique: one doc per workspace (prevents duplicate room entries).
  @@unique([workspaceId, docId])
  // Index for fast lookup by docId within a workspace.
  @@index([workspaceId, docId])
  @@map("yjs_document")
}

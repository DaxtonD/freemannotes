// ─────────────────────────────────────────────────────────────────────────
// Prisma schema for FreemanNotes – Phase 10 (Production Persistence Layer)
//
// PostgreSQL is the canonical source of truth for all document state.
// Yjs in-memory docs are ephemeral runtime state only.
// Redis remains a pub/sub + cache layer only.
// IndexedDB remains client-side cache only.
//
// Design constraints:
//   - System is anonymous (no auth yet) — ready for Phase 11 auth.
//   - No language columns — locale is a client concern.
//   - No markdown-specific schema — metadata lives inside the Yjs map.
//   - Horizontally scalable: multiple app instances share Postgres + Redis.
//
// Migrations:
//   Dev:        npx prisma migrate dev --name <label>
//   Production: npx prisma migrate deploy
//   Client:     npx prisma generate
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  // Output into node_modules/.prisma/client (default location).
  // Docker builds run `prisma generate` after `npm ci`.
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is read from the environment (.env or docker-compose).
  // Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Workspace – lightweight tenant boundary.
//
// Every note collection belongs to exactly one workspace. The default setup
// creates a single "default" workspace automatically (seeded on first boot).
// Future multi-tenant support (Phase 11) can create additional workspaces
// associated with different users or organizations.
// ─────────────────────────────────────────────────────────────────────────
model Workspace {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Human-readable workspace name (e.g. "My Notes", "Team Alpha").
  name String @default("default")

  /// Optional: owner/creator user ID for future auth integration (Phase 11).
  /// Not enforced at DB level — purely informational until auth is added.
  ownerUserId String? @map("owner_user_id")
  systemKind  WorkspaceSystemKind? @map("system_kind")

  /// Timestamps for auditing.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  /// One workspace owns many documents.
  documents Document[]

  /// Phase 11: workspace memberships.
  members WorkspaceMember[]

  /// Phase 11: invite tokens for onboarding.
  invites InviteToken[]

  /// Accepted shared-note placements that should appear inside this workspace.
  incomingSharedPlacements NoteSharePlacement[]
  sentNoteShareInvitations NoteShareInvitation[]
  noteCollaborators NoteCollaborator[]

  // Enforce unique workspace names to prevent accidental duplicates.
  @@unique([name])
  @@unique([systemKind, ownerUserId])
  @@map("workspace")
}

// ─────────────────────────────────────────────────────────────────────────
// Phase 11 — Identity, RBAC, invites, and share tokens.
//
// Notes:
//   - WorkspaceMember provides multi-tenant isolation.
//   - GlobalRole is for system-wide admin.
//   - WorkspaceRole is per-workspace role used for document access.
//   - UserPreference is now authenticated-user scoped, but we keep the
//     existing deleteAfterDays retention preference for Phase 9.
// ─────────────────────────────────────────────────────────────────────────

enum GlobalRole {
  USER
  ADMIN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceSystemKind {
  SHARED_WITH_ME
}

enum NoteShareRole {
  VIEWER
  EDITOR
}

enum NoteShareStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  name         String
  passwordHash String     @map("password_hash")
  role         GlobalRole @default(USER)
  profileImage String?    @map("profile_image")
  disabled     Boolean    @default(false)
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now()) @map("created_at")

  memberships WorkspaceMember[]
  preferences UserPreference?
  devicePreferences UserDevicePreference[]
  sentNoteShareInvitations NoteShareInvitation[] @relation("SentNoteShareInvitations")
  receivedNoteShareInvitations NoteShareInvitation[] @relation("ReceivedNoteShareInvitations")
  noteCollaborations NoteCollaborator[]
  noteSharePlacements NoteSharePlacement[]

  @@map("user")
}

model UserDevicePreference {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Authenticated user identifier.
  userId String @map("user_id") @db.Uuid

  /// Client-generated stable device identifier (stored in localStorage).
  deviceId String @map("device_id")

  /// Per-device appearance preferences.
  theme    String?
  language String?

  /// Per-device workspace selection.
  activeWorkspaceId String? @map("active_workspace_id") @db.Uuid

  /// Per-device UI state: completed items expanded/collapsed in checklist editors.
  checklistShowCompleted Boolean @default(false) @map("checklist_show_completed")

  /// Per-device mobile editor preference: show checklist row delete affordances at all times.
  quickDeleteChecklist Boolean @default(false) @map("quick_delete_checklist")

  /// Per-device UI state: completed items expanded/collapsed per note card.
  /// Shape: { [noteId: string]: boolean }
  noteCardCompletedExpandedByNoteId Json @default("{}") @map("note_card_completed_expanded_by_note_id") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("user_device_preference")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("workspace_member")
}

model InviteToken {
  id          String        @id @default(uuid()) @db.Uuid
  email       String
  workspaceId String        @map("workspace_id") @db.Uuid
  role        WorkspaceRole
  token       String        @unique
  expiresAt   DateTime      @map("expires_at")
  used        Boolean       @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@map("invite_token")
}

model ShareToken {
  id        String        @id @default(uuid()) @db.Uuid
  docId     String        @map("doc_id")
  token     String        @unique
  expiresAt DateTime      @map("expires_at")
  role      WorkspaceRole

  // Optional relation to Document by docId (docId is globally unique).
  document Document? @relation(fields: [docId], references: [docId], onDelete: Cascade)

  @@index([docId])
  @@map("share_token")
}

model NoteShareInvitation {
  id                String          @id @default(uuid()) @db.Uuid
  docId             String          @map("doc_id")
  sourceWorkspaceId String          @map("source_workspace_id") @db.Uuid
  sourceNoteId      String          @map("source_note_id")
  inviterUserId     String          @map("inviter_user_id") @db.Uuid
  inviteeUserId     String?         @map("invitee_user_id") @db.Uuid
  inviteeEmail      String          @map("invitee_email")
  inviteeName       String?         @map("invitee_name")
  role              NoteShareRole
  status            NoteShareStatus @default(PENDING)
  respondedAt       DateTime?       @map("responded_at")
  revokedAt         DateTime?       @map("revoked_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  inviter         User                 @relation("SentNoteShareInvitations", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee         User?                @relation("ReceivedNoteShareInvitations", fields: [inviteeUserId], references: [id], onDelete: SetNull)
  sourceWorkspace Workspace            @relation(fields: [sourceWorkspaceId], references: [id], onDelete: Cascade)
  document        Document             @relation(fields: [docId], references: [docId], onDelete: Cascade)
  collaborator    NoteCollaborator?
  placement       NoteSharePlacement?

  @@index([inviteeEmail])
  @@index([inviteeUserId])
  @@index([sourceWorkspaceId])
  @@index([docId])
  @@index([status])
  @@map("note_share_invitation")
}

model NoteCollaborator {
  id                String        @id @default(uuid()) @db.Uuid
  docId             String        @map("doc_id")
  sourceWorkspaceId String        @map("source_workspace_id") @db.Uuid
  sourceNoteId      String        @map("source_note_id")
  userId            String        @map("user_id") @db.Uuid
  invitationId      String?       @unique @map("invitation_id") @db.Uuid
  role              NoteShareRole
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  revokedAt         DateTime?     @map("revoked_at")

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceWorkspace Workspace            @relation(fields: [sourceWorkspaceId], references: [id], onDelete: Cascade)
  document        Document             @relation(fields: [docId], references: [docId], onDelete: Cascade)
  invitation      NoteShareInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  placement       NoteSharePlacement?

  @@unique([docId, userId])
  @@index([userId])
  @@index([sourceWorkspaceId])
  @@index([docId])
  @@map("note_collaborator")
}

model NoteSharePlacement {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  invitationId      String    @unique @map("invitation_id") @db.Uuid
  collaboratorId    String    @unique @map("collaborator_id") @db.Uuid
  targetWorkspaceId String    @map("target_workspace_id") @db.Uuid
  folderName        String?   @map("folder_name")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitation      NoteShareInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  collaborator    NoteCollaborator    @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  targetWorkspace Workspace           @relation(fields: [targetWorkspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, collaboratorId])
  @@index([userId])
  @@index([targetWorkspaceId])
  @@map("note_share_placement")
}

// ─────────────────────────────────────────────────────────────────────────
// Document – persisted Yjs document state (binary snapshot).
//
// Each Yjs room (identified by `docId`) maps to one row. The `state`
// column stores the full Yjs document as `Y.encodeStateAsUpdate` output
// (Uint8Array → Postgres BYTEA). The server writes this column on a
// debounced schedule and on client disconnect, ensuring durable storage
// that survives server restarts.
//
// `stateVector` stores `Y.encodeStateVector` output for efficient
// incremental sync when clients reconnect.
//
// All note metadata (title, type, trashedAt, etc.) is stored INSIDE the
// Yjs document's metadata Y.Map — not as separate SQL columns. This
// keeps the schema stable as features are added.
// ─────────────────────────────────────────────────────────────────────────
model Document {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Foreign key to the owning workspace.
  workspaceId String @map("workspace_id") @db.Uuid

  /// Yjs room name — matches the room name used by y-websocket.
  /// For individual notes this is the noteId (e.g. "abc123").
  /// For the notes registry this is "__notes_registry__".
  /// Globally unique — one room name maps to exactly one persisted doc.
  docId String @unique @map("doc_id")

  /// Full Yjs document state as Y.encodeStateAsUpdate(doc) output.
  /// This is a binary blob (Uint8Array serialized to Postgres BYTEA).
  state Bytes

  /// Yjs state vector for efficient delta sync.
  /// Stored as Y.encodeStateVector(doc) output.
  stateVector Bytes @map("state_vector")

  /// Timestamp of the initial creation.
  createdAt DateTime @default(now()) @map("created_at")

  /// Timestamp of the last successful persistence write.
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Relation to the parent workspace.
  workspace  Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ShareToken ShareToken[]
  noteShareInvitations NoteShareInvitation[]
  noteCollaborators NoteCollaborator[]

  // Index for fast workspace-scoped queries (list all docs in a workspace).
  @@index([workspaceId])
  @@map("document")
}

// ─────────────────────────────────────────────────────────────────────────
// UserPreference – per-user configurable settings.
//
// Stores user-level preferences that influence server-side behaviour
// (e.g. how long trashed notes are retained before permanent deletion).
// The table is keyed by `userId` — a free-form string that will map to
// a future auth identity (Phase 11). Until then, the server uses a
// deterministic default user ID (e.g. "default").
// ─────────────────────────────────────────────────────────────────────────
model UserPreference {
  /// Primary key — auto-generated UUID.
  id String @id @default(uuid()) @db.Uuid

  /// Phase 11: authenticated user identifier.
  /// Nullable to allow migration from pre-auth installs.
  userId String? @unique @map("user_id") @db.Uuid

  /// Phase 11: theme + language are persisted server-side.
  theme    String?
  language String?

  /// Number of days a trashed note is retained before automatic
  /// permanent deletion. Must be a positive integer.
  /// Default: 30 days.
  deleteAfterDays Int @default(30) @map("delete_after_days")

  /// Timestamps for auditing.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preference")
}
